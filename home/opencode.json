{
  "$schema": "https://opencode.ai/tui.json",
  "instructions": [
    "AGENTS.local.md"
  ],
  "theme": "system",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.1",
    "@dietrichgebert/ponytail@4.8.4"
  ],
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  }
}
